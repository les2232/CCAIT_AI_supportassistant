# Required local configuration
# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=replace-with-generated-secret

# Optional LDAP authentication settings
LDAP_SERVER=
LDAP_PORT=389
LDAP_DOMAIN=
LDAP_USE_SSL=0
LDAP_REQUIRED_GROUP_DN=
ALLOW_DEV_LOGIN=0

# Optional request/feedback logging database path
# Production example: /var/lib/cca-it-support-assistant/it_help_logs.db
IT_SUPPORT_LOG_DB_PATH=

# Session cookie controls
# In production, SESSION_COOKIE_SECURE defaults to enabled when APP_ENV=production.
SESSION_COOKIE_SECURE=
SESSION_COOKIE_SAMESITE=Lax

# Optional OpenAI-backed answer polishing/classification settings
OPENAI_API_KEY=
IT_SUPPORT_LLM_ENABLED=0
IT_SUPPORT_LLM_MODEL=gpt-4.1-mini
IT_SUPPORT_CLASSIFIER_MODEL=gpt-4.1-mini

# Optional Realtime voice settings
ENABLE_REALTIME_SUPPORT=0
OPENAI_REALTIME_PROMPT_ID=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin

# Optional semantic retrieval settings
IT_SUPPORT_EMBEDDINGS_ENABLED=0
IT_SUPPORT_SEMANTIC_MIN_SCORE=0.45

# Optional additive agent metadata settings
ENABLE_AGENTS=0
IT_SUPPORT_AGENT_MODEL=gpt-4.1-mini
IT_SUPPORT_AGENT_TIMEOUT_SECONDS=6

# Optional internal KB notes for explicitly allowed staff users
ENABLE_INTERNAL_KB=0
INTERNAL_KB_ALLOWED_USERS=
INTERNAL_KB_DEFAULT=0
