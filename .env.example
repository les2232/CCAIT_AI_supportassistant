# Required local configuration
# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=replace-with-generated-secret

# Supported default: deterministic local KB-only mode.
# Do not set OPENAI_API_KEY for the default pilot/production deployment.
# OpenAI-backed features require setting IT_SUPPORT_LOCAL_ONLY=0 after review.
IT_SUPPORT_LOCAL_ONLY=1

# Optional LDAP authentication settings
# Production must use LDAPS.
LDAP_SERVER=
LDAP_PORT=636
LDAP_DOMAIN=
LDAP_USE_SSL=1
LDAP_REQUIRED_GROUP_DN=
ALLOW_DEV_LOGIN=0

# Optional request/feedback logging database path
# Production example: /var/lib/cca-it-support-assistant/it_help_logs.db
IT_SUPPORT_LOG_DB_PATH=

# Session cookie controls
# In production, SESSION_COOKIE_SECURE defaults to enabled when APP_ENV=production.
SESSION_COOKIE_SECURE=
SESSION_COOKIE_SAMESITE=Lax

# Login protection
# Set LOGIN_RATE_LIMIT_ATTEMPTS=0 only for isolated local debugging.
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Quarantined optional OpenAI-backed answer polishing/classification settings
# Keep these off in local-only mode.
OPENAI_API_KEY=
IT_SUPPORT_LLM_ENABLED=0
IT_SUPPORT_LLM_MODEL=gpt-4.1-mini
IT_SUPPORT_CLASSIFIER_ENABLED=0
IT_SUPPORT_CLASSIFIER_MODEL=gpt-4.1-mini

# Quarantined optional Realtime voice settings
# Keep this off in local-only mode.
ENABLE_REALTIME_SUPPORT=0
OPENAI_REALTIME_PROMPT_ID=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin

# Optional semantic retrieval settings
# Keep this off in local-only mode so retrieval stays deterministic.
IT_SUPPORT_EMBEDDINGS_ENABLED=0
IT_SUPPORT_SEMANTIC_MIN_SCORE=0.45

# Quarantined optional additive agent metadata settings
# Keep this off in local-only mode.
ENABLE_AGENTS=0
IT_SUPPORT_AGENT_MODEL=gpt-4.1-mini
IT_SUPPORT_AGENT_TIMEOUT_SECONDS=6

# Optional internal KB notes for explicitly allowed staff users
ENABLE_INTERNAL_KB=0
INTERNAL_KB_ALLOWED_USERS=
INTERNAL_KB_DEFAULT=0
